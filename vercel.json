{
  "buildCommand": "cd sama-restau-app && npm run build",
  "outputDirectory": "sama-restau-app/dist",
  "installCommand": "cd sama-restau-app && npm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=0"
        }
      ]
    }
  ]
}
